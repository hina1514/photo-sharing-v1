{
  "$schema": "https://codesandbox.io/schemas/tasks.json",
  "setupTasks": [
    {
      "name": "Cài đặt thư viện",
      "command": "npm install"
    }
  ],
  "tasks": {
    "start-client": {
      "name": "Chạy Frontend",
      "command": "npm start",
      "runAtStart": true,
      "preview": {
        "port": 3000
      }
    },
    "start-server": {
      "name": "Chạy Node Server",
      "command": "cd be/src/server.js && node server.js",
      "runAtStart": true,
      "preview": {
        "port": 5000
      }
    }
  }
}