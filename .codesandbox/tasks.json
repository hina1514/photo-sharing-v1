{
  // These tasks will run in order when initializing your CodeSandbox project.
  "setupTasks": [
    {
      "command": "cd be && npm install",
      "name": "Cài đặt thư viện Backend"
    },
    {
      "command": "cd fe/photo-sharing-v1 && npm install",
      "name": "Cài đặt thư viện Frontend"
    }
  ],

  // These tasks can be run from CodeSandbox. Running one will open a log in the app.
  "tasks": {
    "start-backend": {
      "name": "Chạy Backend",
      "command": "cd be/src && node server.js",
      "runAtStart": true,
      "preview": {
        "port": 3001
      }
    },
    "start-frontend": {
      "name": "Chạy Frontend",
      "command": "cd fe/photo-sharing-v1 && npm start",
      "runAtStart": true,
      "preview": {
        "port": 3000
      }
    }
  }
}
